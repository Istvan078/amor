rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isAdminOrModerator() {
      return signedIn()
        && (
          request.auth.token.admin == true
          || request.auth.token.moderator == true
        );
    }

    function isConversationParticipant() {
      return signedIn() && request.auth.uid in resource.data.participants;
    }

    function isConversationParticipantOnCreate() {
      return signedIn()
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.participants.size() == 2;
    }

    function validReportReason(reason) {
      return reason in [
        'fakeProfile',
        'harassment',
        'spam',
        'inappropriateContent',
        'other',
        'conversation_report'
      ];
    }

    function validReportStatus(status) {
      return status in [
        'open',
        'reviewed',
        'dismissed',
        'action_taken'
      ];
    }

    function validReportCreate(reportId) {
      return request.resource.data.keys().hasOnly([
          'reportId',
          'reporterUid',
          'reportedUid',
          'reason',
          'description',
          'createdAt',
          'status'
        ])
        && request.resource.data.keys().hasAll([
          'reportId',
          'reporterUid',
          'reportedUid',
          'reason',
          'description',
          'createdAt',
          'status'
        ])
        && request.resource.data.reportId == reportId
        && request.resource.data.reporterUid == request.auth.uid
        && request.resource.data.reporterUid is string
        && request.resource.data.reportedUid is string
        && request.resource.data.reportedUid != request.auth.uid
        && request.resource.data.description is string
        && validReportReason(request.resource.data.reason)
        && request.resource.data.status == 'open'
        && request.resource.data.createdAt is timestamp;
    }

    match /users/{uid} {
      allow read: if signedIn();
      allow create, update, delete: if isOwner(uid) || isAdminOrModerator();

      match /billing/{billingDocument} {
        allow read: if isOwner(uid) || isAdminOrModerator();
        allow write: if isAdminOrModerator();
      }
    }

    match /reports/{reportId} {
      allow create: if signedIn() && validReportCreate(reportId);
      allow read, delete: if isAdminOrModerator();
      allow update: if isAdminOrModerator()
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['status'])
        && validReportStatus(request.resource.data.status);
    }

    match /conversations/{conversationId} {
      allow create: if isConversationParticipantOnCreate();
      allow read: if isConversationParticipant() || isAdminOrModerator();
      allow update: if isConversationParticipant();
      allow delete: if isAdminOrModerator();

      match /messages/{messageId} {
        function conversation() {
          return get(/databases/$(database)/documents/conversations/$(conversationId));
        }

        function isMessageParticipant() {
          return signedIn() && request.auth.uid in conversation().data.participants;
        }

        allow read: if isMessageParticipant() || isAdminOrModerator();
        allow create: if isMessageParticipant()
          && request.resource.data.senderUid == request.auth.uid;
        allow update: if isMessageParticipant();
        allow delete: if isAdminOrModerator();
      }
    }

    match /matches/{legacyDocument=**} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
